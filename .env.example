# Local PostgreSQL connection
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5433
POSTGRESQL_USER=app_user
POSTGRESQL_PASSWORD=change_me
POSTGRESQL_DB=contact_service

# Optional OpenAI integration. Without both values, fallback mode is used.
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=your-model
OPENAI_TIMEOUT_SECONDS=5

# Optional SMTP integration. Without a complete configuration, email statuses
# are returned as failed while the contact is still saved.
# SMTP_HOST=smtp.example.com
SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=change_me
# SMTP_SENDER_EMAIL=user@example.com
# SMTP_OWNER_EMAIL=owner@example.com
SMTP_START_TLS=true
SMTP_USE_TLS=false
SMTP_TIMEOUT_SECONDS=10

# Request logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5

# Anti-spam
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=900
TRUST_PROXY_HEADERS=false

# JSON array. Add the deployed frontend origin when it exists.
CORS_ORIGINS=["http://localhost:3000"]

# Optional application-owned secret protecting GET /api/metrics.
# Send the same value in the X-Metrics-API-Key request header.
# METRICS_API_KEY=replace_with_a_long_random_value
